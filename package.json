{
  "name": "ardupilot-uav-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "app": "concurrently -k --success first \"npm:dev:server\" \"npm:dev:client\" \"npm:own:browser\"",
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 127.0.0.1",
    "dev:server": "node --watch server/index.js",
    "own:browser": "node scripts/launch-design-browser.mjs",
    "own:browser:kiosk": "node scripts/launch-design-browser.mjs --kiosk",
    "design:browser": "node scripts/launch-design-browser.mjs",
    "design:browser:kiosk": "node scripts/launch-design-browser.mjs --kiosk",
    "test": "node --test server/localOrigin.test.js",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "github:upload": "node scripts/prepare-github-upload.mjs"
  },
  "dependencies": {
    "@xyflow/react": "^12.9.3",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "playwright": "^1.61.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
